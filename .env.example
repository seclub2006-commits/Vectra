# Настройки подключения к ядру (gRPC)
CORE_HOST=localhost
CORE_PORT=9876
CORE_PASSWORD=your_secure_password_here

# Режим работы: paper, live, backtest
TRADING_MODE=paper

# Путь к файлу базы данных (SQLite)
DATABASE_URL=sqlite+aiosqlite:///vectra.db

# Сколько дней хранить логи (в БД и в файлах .log)
LOG_RETENTION_DAYS=30

# Ключ шифрования (генерируется автоматически при первом запуске)
ENCRYPTION_KEY=

# Веб-сервер
WEB_HOST=0.0.0.0
WEB_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT аутентификация для веб-интерфейса (можно оставить для будущих расширений)
JWT_SECRET_KEY=ваш_секретный_ключ_длинный_и_случайный
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (опционально)
REDIS_URL=redis://localhost:6379/0

# Максимальное количество одновременно работающих ботов
MAX_CONCURRENT_BOTS=50